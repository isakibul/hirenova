PORT=4000

# Database
DATABASE_CONNECTION_URL=mongodb://localhost:27017
DB_NAME=hirenova

# Redis
# In production, prefer REDIS_URL or set both REDIS_HOST and REDIS_PORT.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# Email
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Hirenova <no-reply@hirenova.com>"
# Local email preview UI from docker-compose MailHog: http://localhost:8025
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Auth
ACCESS_TOKEN_SECRET=replace-with-a-strong-access-token-secret
ACCESS_TOKEN_EXPIRES_IN=8h
AUTH_COOKIE_MAX_AGE_SECONDS=28800
ACCESS_TOKEN_REFRESH_WINDOW_SECONDS=3600
EMAIL_SECRET=replace-with-a-strong-email-secret
CSRF_SECRET=replace-with-a-strong-csrf-secret
OBSERVABILITY_HASH_SECRET=replace-with-a-strong-observability-secret
ERROR_WEBHOOK_URL=
AUDIT_LOG_RETENTION_DAYS=90
EMAIL_EVENT_RETENTION_DAYS=90
RATE_LIMIT_STORE=memory

# Resume object storage (Docker MinIO by default, S3-compatible in production)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=hirenova-resumes
S3_ACCESS_KEY=hirenova
S3_SECRET_KEY=hirenova-minio-secret
S3_FORCE_PATH_STYLE=true
S3_REQUEST_TIMEOUT_MS=5000

# OpenRouter
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_RECOMMENDATION_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_MS=7000
JOB_RECOMMENDATION_AI_LIMIT=5
JOB_RECOMMENDATION_CANDIDATE_LIMIT=100
JOB_RECOMMENDATION_MAX_RESULTS=5
JOB_RECOMMENDATION_MIN_SCORE=50
JOB_RECOMMENDATION_CACHE_TTL_MS=21600000
OPENROUTER_APP_NAME=HireNova
OPENROUTER_SITE_URL=http://localhost:3000
