{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build",
    "start": "next start",
    "start:e2e": "next build && next start --hostname 127.0.0.1",
    "test": "node --test --no-warnings \"test/**/*.test.mjs\"",
    "test:coverage": "node --test --no-warnings --experimental-test-coverage --test-coverage-lines=80 --test-coverage-branches=70 --test-coverage-functions=80 --test-coverage-include='app/_lib/**/*.js' --test-coverage-include='app/(admin)/manage-newsletter/newsletterUtils.js' --test-coverage-include='app/(account)/messages/messageUtils.js' --test-coverage-include='app/(jobs)/jobs/jobDisplay.js' \"test/**/*.test.mjs\"",
    "test:e2e": "playwright test",
    "test:e2e:local": "playwright test",
    "test:e2e:external": "E2E_START_BACKEND=false playwright test",
    "lint": "eslint",
    "check": "npm run test:coverage && npm run lint && npm run build"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "framer-motion": "^12.38.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4"
  }
}
