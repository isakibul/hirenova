# Browser-visible realtime server origin for Socket.IO.
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000

# Backend API URL used by server components and browser API helpers.
BACKEND_API_URL=http://localhost:4000/api/v1
# Optional. Leave unset to use the same-origin /api/v1 proxy.
# NEXT_PUBLIC_BACKEND_API_URL=http://localhost:4000/api/v1
# Optional. Only set true if the browser must call the backend directly.
# NEXT_PUBLIC_DIRECT_BACKEND_API=false
