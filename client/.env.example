# Server-only URL used by Next.js route handlers and server components.
BACKEND_API_URL=http://localhost:4000/api/v1

# Browser-visible realtime server origin for Socket.IO.
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000

# Public origin for NextAuth callbacks.
NEXTAUTH_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-strong-random-secret
