{
  "name": "hirenova",
  "version": "1.0.0",
  "description": "Full-stack hiring platform with job search, applications, employer workflows, admin operations, realtime messaging, notifications, email, and production-readiness checks.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "dev:client": "npm --prefix client run dev",
    "start": "node src/index.js",
    "test": "node --test \"test/**/*.test.js\"",
    "test:backend": "npm test",
    "test:client": "npm --prefix client run test",
    "lint:client": "npm --prefix client run lint",
    "build:client": "npm --prefix client run build",
    "check:backend": "npm test",
    "check:client": "npm --prefix client run check",
    "check": "npm run check:backend && npm run check:client"
  },
  "keywords": [
    "hiring-platform",
    "job-board",
    "nextjs",
    "express",
    "mongodb",
    "socket.io",
    "portfolio"
  ],
  "author": "Isakibul",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "mongoose": "^8.16.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.5",
    "pdf-parse": "^2.4.5",
    "redis": "^5.6.0",
    "socket.io": "^4.8.3",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
